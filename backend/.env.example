# Example environment variables for Polvorina backend
# Copy to .env and fill the secrets before starting the server.

# API key for your upstream provider (DeepSeek or similar)
DEEPSEEK_API_KEY=

# Upstream endpoint (optional). If empty, server uses the default built-in URL.
DEEPSEEK_API_URL=

# Model name supported by your provider (example: deepseek-chat-4)
DEEPSEEK_MODEL=

# Port for the Node app (cPanel usually sets this automatically)
PORT=3000

# Optional tuning
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=1024

# If set to 1 (or true), server will serve the frontend static files from the
# project parent folder (useful when deploying both frontend and backend under
# the same app in cPanel).
SERVE_STATIC=0
